{
  "entities": {
    "Patient": {
      "title": "Patient",
      "description": "Information about a patient.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "avatar": { "type": "string" },
        "detailsAvatar": { "type": "string" },
        "lastVisit": { "type": "string" },
        "tier": { "type": "string" },
        "since": { "type": "string" },
        "totalSpent": { "type": "number" },
        "proceduresCount": { "type": "number" },
        "lastPhotoDate": { "type": "string" },
        "status": { "type": "string" },
        "ltv": { "type": "string" },
        "birthdate": { "type": "string" },
        "allergies": { "type": "string" },
        "medications": { "type": "string" },
        "previousProcedures": { "type": "string" },
        "evolutionNotes": { "type": "string" },
        "beforePhoto": { "type": "string" },
        "afterPhoto": { "type": "string" },
        "timeline": {
           "type": "array",
           "items": { "$ref": "#/entities/TimelineItem" }
        }
      },
      "required": ["name"]
    },
    "TimelineItem": {
      "title": "TimelineItem",
      "description": "Patient timeline item.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "date": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "AppUser": {
      "title": "AppUser",
      "description": "A staff user in the app.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "username": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff", "prestador"] },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "specialty": { "type": "string" },
        "phone": { "type": "string" },
        "commissionRate": { "type": "number" }
      },
      "required": ["name", "username", "role"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "A scheduled appointment.",
      "type": "object",
      "properties": {
        "time": { "type": "string" },
        "patientName": { "type": "string" },
        "patientAvatar": { "type": "string" },
        "procedure": { "type": "string" },
        "status": { "type": "string" },
        "professional": { "type": "string" },
        "category": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["time", "patientName", "procedure"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction.",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string" },
        "value": { "type": "number" }
      },
      "required": ["date", "description", "value"]
    }
  },
  "firestore": {
    "/patients/{patientId}": {
      "schema": "#/entities/Patient",
      "description": "Stores patient records."
    },
    "/users/{userId}": {
      "schema": "#/entities/AppUser",
      "description": "Stores system users."
    },
    "/appointments/{appointmentId}": {
      "schema": "#/entities/Appointment",
      "description": "Stores appointments."
    },
    "/transactions/{transactionId}": {
      "schema": "#/entities/Transaction",
      "description": "Stores financial transactions."
    }
  }
}
