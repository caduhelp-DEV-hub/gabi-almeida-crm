# Supabase - chaves públicas (NEXT_PUBLIC_*) são expostas ao frontend.
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Chave de service role (privada) - usada apenas no servidor Next.js.
# NUNCA exponha esta chave ao frontend.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Segredo do JWT usado pela autenticação customizada (lib/auth.ts).
# Gere um valor aleatório longo (ex.: openssl rand -hex 32).
JWT_SECRET="change-me-to-a-strong-random-secret"

# GEMINI_API_KEY: Necessária para o assistente AI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: URL onde a aplicação está hospedada.
APP_URL="MY_APP_URL"
